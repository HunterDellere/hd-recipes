{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "hd-recipes entry",
  "type": "object",
  "required": ["type", "category", "title", "status"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["recipe", "ingredient", "technique", "cuisine", "equipment", "hub", "family"]
    },
    "category": {
      "type": "string",
      "enum": ["recipes", "ingredients", "techniques", "cuisines", "equipment", "hubs", "explore"]
    },
    "family": {
      "type": "string",
      "enum": ["cook", "pantry", "learn", "traverse", "explore"]
    },
    "status": { "type": "string", "enum": ["stub", "draft", "complete"] },
    "content_review": { "type": "string", "enum": ["pending", "verified", "needs-work"] },
    "content_sources": { "type": "array", "items": { "type": "string" } },
    "title": { "type": "string", "minLength": 1 },
    "desc": { "type": "string" },
    "metaDesc": { "type": "string" },
    "pageTitle": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "when_to_use": { "type": "string", "description": "Technique pages: when this method earns its place over alternatives." },
    "failure_modes": { "type": "string", "description": "Technique pages: what goes wrong, why, how to recover." },
    "practice_notes": { "type": "string", "description": "Technique pages: extra reps for building the muscle." },
    "updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
    "last_made": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },

    "servings": { "type": "integer", "minimum": 1 },
    "yield_note": { "type": "string" },
    "time": {
      "type": "object",
      "properties": {
        "prep_min": { "type": "integer", "minimum": 0 },
        "cook_min": { "type": "integer", "minimum": 0 },
        "total_min": { "type": "integer", "minimum": 0 },
        "active_min": { "type": "integer", "minimum": 0 }
      }
    },
    "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
    "cuisine": { "type": "string" },
    "course": {
      "type": "string",
      "enum": ["breakfast", "lunch", "dinner", "snack", "dessert", "side", "sauce", "drink", "stock", "appetizer", "bread"]
    },
    "diet": {
      "type": "array",
      "items": { "type": "string", "enum": ["vegetarian", "vegan", "gluten-free", "dairy-free", "nut-free", "low-carb", "pescatarian"] }
    },
    "source": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "note": { "type": "string" }
      }
    },

    "ingredients": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item", "qty"],
        "properties": {
          "item": { "type": "string", "description": "Display text, e.g. 'yellow onion'" },
          "slug": { "type": "string", "description": "Optional: ingredients/<slug>.md to crosslink" },
          "qty": { "type": ["number", "string"], "description": "Numeric for scaling; string allowed for 'to taste'" },
          "unit": { "type": "string", "description": "g, kg, ml, l, tsp, tbsp, cup, oz, lb, each, pinch" },
          "prep": { "type": "string", "description": "e.g. 'finely diced'" },
          "note": { "type": "string" },
          "optional": { "type": "boolean" },
          "group": { "type": "string", "description": "e.g. 'For the sauce'" },
          "usda_fdc_id": { "type": "integer", "description": "Override per-recipe nutrition lookup" }
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": { "type": "string" },
          "technique": { "type": "string", "description": "Optional techniques/<slug>.md to crosslink" },
          "time_min": { "type": "integer" },
          "image": { "type": "string" }
        }
      }
    },
    "techniques": { "type": "array", "items": { "type": "string" }, "description": "Slugs in techniques/" },
    "equipment": { "type": "array", "items": { "type": "string" }, "description": "Slugs in equipment/" },
    "notes": { "type": "string" },

    "substitutions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "for": { "type": "string" },
          "use": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "seasonality": { "type": "string" },
    "storage": { "type": "string" },

    "members": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "slug": { "type": "string" },
          "label": { "type": "string" },
          "note": { "type": "string" }
        }
      },
      "description": "For hub pages: curated recipe collections"
    }
  }
}
